<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RUTHRESH S | EEE Engineer | Portfolio & Certifications</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080808;
    --surface: #111111;
    --border: #1e1e1e;
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --gold-dim: rgba(201,168,76,0.12);
    --text: #e8e4dc;
    --muted: #6b6660;
    --accent: #c9a84c;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-weight: 300;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom Cursor */
  .cursor {
    width: 8px; height: 8px;
    background: var(--gold);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: transform 0.1s, width 0.3s, height 0.3s, background 0.3s;
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1px solid rgba(201,168,76,0.5);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition: transform 0.15s ease-out, width 0.3s, height 0.3s;
  }
  body:hover .cursor { opacity: 1; }

  /* Noise overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9000;
    opacity: 0.4;
  }

  /* Navigation */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 60px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.4s, background 0.4s, backdrop-filter 0.4s;
  }
  nav.scrolled {
    border-color: var(--border);
    background: rgba(8,8,8,0.85);
    backdrop-filter: blur(20px);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    color: var(--gold);
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: 48px;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--gold); }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 60px 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-grid-line {
    position: absolute;
    top: 0; left: 50%;
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, var(--border) 30%, var(--border) 70%, transparent);
    opacity: 0.5;
  }
  .hero-circle {
    position: absolute;
    right: -200px; top: 50%;
    transform: translateY(-50%);
    width: 600px; height: 600px;
    border-radius: 50%;
    border: 1px solid var(--border);
    opacity: 0.3;
    animation: rotateSlow 60s linear infinite;
  }
  .hero-circle::after {
    content: '';
    position: absolute;
    inset: 80px;
    border-radius: 50%;
    border: 1px solid var(--border);
  }
  @keyframes rotateSlow { to { transform: translateY(-50%) rotate(360deg); } }

  .hero-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4rem, 9vw, 9rem);
    font-weight: 300;
    line-height: 0.92;
    max-width: 900px;
    opacity: 0;
    animation: fadeUp 0.9s 0.4s forwards;
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold);
  }
  .hero-sub {
    margin-top: 56px;
    max-width: 540px;
    font-size: 0.8rem;
    line-height: 2;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 0.9s 0.6s forwards;
  }
  .hero-cta {
    margin-top: 64px;
    display: flex;
    gap: 24px;
    opacity: 0;
    animation: fadeUp 0.9s 0.8s forwards;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 36px;
    background: var(--gold);
    color: #000;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 36px;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.3s, color 0.3s, transform 0.3s;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }

  .hero-scroll {
    position: absolute;
    bottom: 48px;
    left: 60px;
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 1s 1.2s forwards;
  }
  .scroll-line {
    width: 60px;
    height: 1px;
    background: var(--border);
    position: relative;
    overflow: hidden;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    left: -100%;
    top: 0;
    width: 100%;
    height: 100%;
    background: var(--gold);
    animation: lineMove 2s 1.5s infinite;
  }
  @keyframes lineMove { 0%{left:-100%} 100%{left:100%} }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Stats bar */
  .stats-bar {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    overflow: hidden;
  }
  .stat-item {
    padding: 40px 60px;
    border-right: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    transition: background 0.4s;
  }
  .stat-item:last-child { border-right: none; }
  .stat-item:hover { background: var(--gold-dim); }
  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 8px;
  }

  /* Section layout */
  section { position: relative; }
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 100px 60px 60px;
    border-bottom: 1px solid var(--border);
  }
  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.05;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .section-link {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: color 0.3s;
  }
  .section-link:hover { color: var(--gold); }
  .section-link::after {
    content: '→';
    transition: transform 0.3s;
  }
  .section-link:hover::after { transform: translateX(4px); }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }
  .project-card {
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 56px;
    position: relative;
    overflow: hidden;
    transition: background 0.4s;
    cursor: pointer;
  }
  .project-card:nth-child(2n) { border-right: none; }
  .project-card:hover { background: var(--surface); }
  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 0; height: 2px;
    background: var(--gold);
    transition: width 0.5s;
  }
  .project-card:hover::before { width: 100%; }

  .project-number {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    margin-bottom: 40px;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }
  .tag {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 0;
    transition: border-color 0.3s, color 0.3s;
  }
  .project-card:hover .tag { border-color: var(--gold); color: var(--gold); }
  .project-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: 20px;
    transition: color 0.3s;
  }
  .project-card:hover .project-name { color: var(--gold); }
  .project-desc {
    font-size: 0.75rem;
    line-height: 2;
    color: var(--muted);
    margin-bottom: 36px;
  }
  .project-links {
    display: flex;
    gap: 20px;
  }
  .project-link {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .project-link:hover { color: var(--gold); }
  .project-link svg { width: 14px; height: 14px; }

  /* Featured project */
  .project-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    border-right: none;
    background: var(--surface);
  }
  .project-card.featured .project-name { font-size: 3rem; }
  .featured-visual {
    aspect-ratio: 16/9;
    background: var(--bg);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .featured-visual-inner {
    width: 80%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .vis-bar {
    background: var(--border);
    border-radius: 1px;
    animation: barGrow 2s ease-in-out infinite alternate;
  }
  .vis-bar:nth-child(1) { height: 60px; animation-delay: 0s; }
  .vis-bar:nth-child(2) { height: 90px; animation-delay: 0.2s; }
  .vis-bar:nth-child(3) { height: 45px; animation-delay: 0.4s; }
  @keyframes barGrow {
    from { opacity: 0.3; transform: scaleY(0.8); }
    to { opacity: 1; background: var(--gold); transform: scaleY(1); }
  }

  /* Skills Section */
  .skills-section { padding: 0; }
  .skills-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 1px solid var(--border);
  }
  .skill-group {
    padding: 60px;
    border-right: 1px solid var(--border);
  }
  .skill-group:last-child { border-right: none; }
  .skill-group-title {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .skill-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--muted);
    transition: color 0.3s;
  }
  .skill-item:last-child { border-bottom: none; }
  .skill-item:hover { color: var(--text); }
  .skill-bar {
    width: 80px;
    height: 2px;
    background: var(--border);
    position: relative;
    overflow: hidden;
  }
  .skill-fill {
    position: absolute;
    left: 0; top: 0;
    height: 100%;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s ease;
  }
  .skill-item:hover .skill-fill { transform: scaleX(1); }

  /* Timeline / Experience */
  .experience-section { }
  .timeline {
    padding: 0 60px 80px;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 60px;
    padding: 56px 0;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-date {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--gold);
    text-transform: uppercase;
    padding-top: 4px;
  }
  .timeline-content {}
  .timeline-role {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 300;
    margin-bottom: 8px;
  }
  .timeline-company {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    margin-bottom: 20px;
    text-transform: uppercase;
  }
  .timeline-desc {
    font-size: 0.75rem;
    line-height: 2;
    color: var(--muted);
    max-width: 580px;
  }

  /* Certifications Section */
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    padding: 40px 60px;
  }
  .cert-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0;
    padding: 1.5rem;
    transition: all 0.3s;
    cursor: pointer;
  }
  .cert-card:hover {
    transform: translateY(-4px);
    border-color: var(--gold);
    background: var(--gold-dim);
  }
  .cert-header {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .cert-icon {
    font-size: 1.8rem;
    color: var(--gold);
  }
  .cert-title {
    font-weight: 600;
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--text);
  }
  .cert-issuer {
    font-size: 0.7rem;
    color: var(--gold);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }
  .cert-date {
    font-size: 0.65rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cert-badge {
    display: inline-block;
    background: var(--gold);
    color: #000;
    font-size: 0.6rem;
    padding: 0.2rem 0.6rem;
    margin-top: 0.75rem;
    letter-spacing: 0.05em;
  }

  /* Contact */
  .contact-section {
    border-top: 1px solid var(--border);
  }
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }
  .contact-left {
    padding: 100px 60px;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .contact-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
  }
  .contact-title em { font-style: italic; color: var(--gold); }
  .contact-email {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-style: italic;
    color: var(--gold);
    text-decoration: none;
    transition: color 0.3s;
  }
  .contact-email:hover { color: var(--gold-light); }
  .contact-right {
    padding: 100px 60px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .social-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--muted);
    transition: color 0.3s, padding-left 0.3s;
  }
  .social-item:first-child { border-top: 1px solid var(--border); }
  .social-item:hover { color: var(--gold); padding-left: 12px; }
  .social-name {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .social-arrow { font-size: 1.2rem; transition: transform 0.3s; }
  .social-item:hover .social-arrow { transform: translateX(6px); }

  /* Footer */
  footer {
    padding: 40px 60px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* Scroll animations */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s, transform 0.8s;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Marquee */
  .marquee-section {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: 20px 0;
    background: var(--surface);
  }
  .marquee-track {
    display: flex;
    gap: 60px;
    animation: marquee 25s linear infinite;
    white-space: nowrap;
  }
  .marquee-item {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 60px;
    flex-shrink: 0;
  }
  .marquee-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }
  @keyframes marquee { to { transform: translateX(-50%); } }

  /* Responsive */
  @media (max-width: 768px) {
    nav { padding: 20px 24px; }
    .nav-links { display: none; }
    .hero { padding: 100px 24px 60px; }
    .stats-bar { grid-template-columns: repeat(2, 1fr); }
    .stat-item { padding: 28px 24px; }
    .section-header { padding: 60px 24px 40px; flex-direction: column; align-items: flex-start; gap: 20px; }
    .projects-grid { grid-template-columns: 1fr; }
    .project-card { border-right: none; padding: 36px 24px; }
    .project-card.featured { grid-column: 1; display: flex; flex-direction: column; }
    .skills-list { grid-template-columns: 1fr; }
    .skill-group { border-right: none; padding: 36px 24px; }
    .timeline { padding: 0 24px 60px; }
    .timeline-item { grid-template-columns: 1fr; gap: 12px; }
    .contact-inner { grid-template-columns: 1fr; }
    .contact-left { padding: 60px 24px; }
    .contact-right { padding: 40px 24px; }
    footer { padding: 24px; flex-direction: column; gap: 12px; text-align: center; }
    .cert-grid { padding: 24px; }
  }
</style>
</head>
<body>

<!-- Custom Cursor -->
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- Navigation -->
<nav id="navbar">
  <a href="#" class="nav-logo">RUTHRESH S</a>
  <ul class="nav-links">
    <li><a href="#projects">Projects</a></li>
    <li><a href="#certifications">Certifications</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- Hero -->
<section class="hero" id="home">
  <div class="hero-grid-line"></div>
  <div class="hero-circle"></div>
  <p class="hero-eyebrow">⚡ EEE Engineer | Web Developer | JLPT N5 Certified</p>
  <h1 class="hero-title">RUTHRESH S<br><em>Electrical & Electronics</em><br>Engineering Student</h1>
  <p class="hero-sub">3rd Year BE EEE @ Karpagam College of Engineering. Passionate about merging electrical systems with modern web technologies. Building intelligent solutions, AI-powered applications, and contributing to smart grid innovations.</p>
  <div class="hero-cta">
    <a href="#certifications" class="btn-primary">View Certifications</a>
    <a href="#contact" class="btn-ghost">Get In Touch</a>
  </div>
  <div class="hero-scroll">
    <div class="scroll-line"></div>
    Scroll to explore
  </div>
</section>

<!-- Stats Bar -->
<div class="stats-bar">
  <div class="stat-item reveal">
    <div class="stat-number">15+</div>
